{% extends 'base.html.twig' %}

{% block title %}Edit Pet #{{ pet.id }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-4">Edit Pet #{{ pet.id }}</h1>
        <form method="POST" action="{{ path('web_pets_edit_post', {id: pet.id}) }}">
            <div class="mb-3">
                <label for="name" class="form-label">Name *</label>
                <input type="text" id="name" name="name" class="form-control" value="{{ pet.name }}" required>
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select">
                    {% for s in ['available', 'pending', 'sold'] %}
                        <option value="{{ s }}" {{ pet.status == s ? 'selected' : '' }}>{{ s }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="mb-3">
                <label for="photoUrl" class="form-label">Photo URL</label>
                <input type="url" id="photoUrl" name="photoUrl" class="form-control" value="{{ pet.photoUrls|first|default('') }}">
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Update</button>
                <a href="{{ path('web_pets_show', {id: pet.id}) }}" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
