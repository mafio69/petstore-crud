{% extends 'base.html.twig' %}

{% block title %}Pet #{{ pet.id }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-4">Pet #{{ pet.id }}</h1>
        <table class="table table-bordered">
            <tr><th>ID</th><td>{{ pet.id }}</td></tr>
            <tr><th>Name</th><td>{{ pet.name }}</td></tr>
            <tr><th>Status</th><td>{{ pet.status }}</td></tr>
            <tr><th>Photo URLs</th><td>{{ pet.photoUrls|join(', ') }}</td></tr>
        </table>
        <div class="d-flex gap-2">
            <a href="{{ path('web_pets_edit', {id: pet.id}) }}" class="btn btn-warning">Edit</a>
            <form method="POST" action="{{ path('web_pets_delete', {id: pet.id}) }}" onsubmit="return confirm('Delete this pet?')">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
            <a href="{{ path('web_pets_index') }}" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>
{% endblock %}
